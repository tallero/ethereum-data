const
  _libcrash_module =
    require(
      "crash-js");
/* global
     _json_read:
       writable */
_json_read =
  _libcrash_module._json_read;
/* global
     _path_join:
       writable */
_path_join =
  _libcrash_module._path_join;

function
  _data_split_get(
    _chain_id) {
  const
    _path =
      _path_join(
        ["chains",
         `${_chain_id}.json`]);
  const
    _data =
      _json_read(
        _path);
  return _data;
}

function
  _data_get(
   _chain_id) {
  let
    _data;
  if ( typeof(
         _chain_id) == "undefined" ||
       _chain_id == "" ) {
    _data =
      _data_unified_get();
  }
  else {
    _data =
      _data_split_get(
        _chain_id);
  }
  return _data;
}

function
  _data_unified_get(
    _chain_id) {
  const
    _path =
      _path_join(
        ["chains",
         `chains.json`]);
  const
    _data =
      _json_read(
        _path);
  return _data;
}

module.exports = {
  _data_get:
    _data_get,
  _data_split_get:
    _data_split_get,
  _data_unified_get:
    _data_unified_get
}
